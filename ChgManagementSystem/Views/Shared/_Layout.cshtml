<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - ChgManagementSystem</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/ChgManagementSystem.styles.css"
          asp-append-version="true" />
</head>

<body>

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">

            <div class="container-fluid">

                <a class="navbar-brand fw-bold"
                   asp-controller="Home"
                   asp-action="Index">

                    Church CMS

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="navbarNav">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">

                                Home

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Circuits"
                               asp-action="Index">

                                Circuits

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Branches"
                               asp-action="Index">

                                Branches

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Members"
                               asp-action="Index">

                                Members

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="TitheRecords"
                               asp-action="Index">

                                Tithes

                            </a>

                        </li>

                    </ul>

                    <!-- LOGIN / LOGOUT -->
                    <partial name="_LoginPartial" />

                </div>

            </div>

        </nav>

    </header>

    <main role="main">

        @RenderBody()

    </main>

    
    <footer class="footer text-white text-center py-2">

        <small>
            &copy; 2026 - ChgManagementSystem
        </small>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
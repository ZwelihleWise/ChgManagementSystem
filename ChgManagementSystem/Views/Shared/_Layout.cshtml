
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - CHG</title>
    <link rel="icon" type="image/jpeg" href="~/img/icon.jpeg">

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/ChgManagementSystem.styles.css"
          asp-append-version="true" />
</head>

<body>

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">

            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center"
                   asp-controller="Home"
                   asp-action="Index">

                    <img src="~/img/icon.jpeg"
                         asp-append-version="true"
                         alt="Church Logo"
                         class="navbar-logo me-3" />

                   

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="navbarNav">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">

                                Home

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Circuits"
                               asp-action="Index">

                                Circuits

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Branches"
                               asp-action="Index">

                                Branches

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Members"
                               asp-action="Index">

                                Members

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="TitheRecords"
                               asp-action="Index">

                                Tithes

                            </a>

                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="NewsPosts"
                               asp-action="Index">
                                News & Events
                            </a>
                        </li>
                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="GalleryAlbums"
                               asp-action="Index">

                                Gallery

                            </a>

                        </li>

                        @if (User.IsInRole("Admin") || User.IsInRole("Deacon"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="NewsPosts"
                                   asp-action="Create">
                                    Create Post
                                </a>
                            </li>
                            <li class="nav-item">

                                <a class="nav-link"
                                   asp-controller="WebsiteSettings"
                                   asp-action="Edit">

                                    Website Settings

                                </a>

                            </li>
                        }

                    </ul>

                    <!-- LOGIN / LOGOUT -->
                    <partial name="_LoginPartial" />

                </div>

            </div>

        </nav>

    </header>

    <main role="main">

        @RenderBody()

    </main>

    
    <footer class="footer text-white text-center py-2">

        <small>
            &copy; 2026 - The Church of The Holy Ghost. built by Wisecode IT Solutions PTY ltd.
        </small>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
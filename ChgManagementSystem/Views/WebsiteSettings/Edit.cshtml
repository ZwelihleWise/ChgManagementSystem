@model ChgManagementSystem.Models.WebsiteSettings

@{
    ViewData["Title"] = "Website Settings";
}

<div class="container mt-4">

    <div class="table-container">

        <h2 class="mb-4">Website Settings</h2>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        <form asp-action="Edit"
              method="post"
              enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger"></div>

            <input asp-for="Id" type="hidden" />

            <h4 class="mt-3">Church Information</h4>
            <hr />

            <div class="mb-3">
                <label asp-for="ChurchName" class="form-label"></label>
                <input asp-for="ChurchName" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Motto" class="form-label"></label>
                <input asp-for="Motto" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="WelcomeMessage" class="form-label"></label>
                <textarea asp-for="WelcomeMessage"
                          rows="5"
                          class="form-control"></textarea>
            </div>
            <hr />

            <h4>Church Images</h4>

            <div class="mb-3">

                <label class="form-label">
                    Church Logo
                </label>

                <input type="file"
                       name="Logo"
                       class="form-control" />

                @if (!string.IsNullOrEmpty(Model.LogoPath))
                {
                    <img src="@Model.LogoPath"
                         class="img-thumbnail mt-2"
                         style="max-height:120px;" />
                }

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Hero Image
                </label>

                <input type="file"
                       name="HeroImage"
                       class="form-control" />

                @if (!string.IsNullOrEmpty(Model.HeroImagePath))
                {
                    <img src="@Model.HeroImagePath"
                         class="img-fluid mt-2 rounded"
                         style="max-height:180px;" />
                }

            </div>

            <h4 class="mt-4">Live Stream</h4>
            <hr />

            <div class="mb-3">
                <label asp-for="LiveYoutubeUrl" class="form-label">
                    YouTube Live Link
                </label>
                <input asp-for="LiveYoutubeUrl" class="form-control" />
            </div>

            <h4 class="mt-4">Social Media</h4>
            <hr />

            <div class="mb-3">
                <label asp-for="FacebookUrl"></label>
                <input asp-for="FacebookUrl" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="InstagramUrl"></label>
                <input asp-for="InstagramUrl" class="form-control" />
            </div>

            <h4 class="mt-4">Contact Information</h4>
            <hr />

            <div class="mb-3">
                <label asp-for="Phone"></label>
                <input asp-for="Phone" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Address"></label>
                <textarea asp-for="Address"
                          class="form-control"></textarea>
            </div>

            <h4 class="mt-4">Service Times</h4>
            <hr />

            <div class="row">

                <div class="col-md-4">
                    <label asp-for="SundayService"></label>
                    <input asp-for="SundayService"
                           class="form-control" />
                </div>

                <div class="col-md-4">
                    <label asp-for="Tuesday_Thursday_Service"></label>
                    <input asp-for="Tuesday_Thursday_Service"
                           class="form-control" />
                </div>

                <div class="col-md-4">
                    <label asp-for="SaturdayService"></label>
                    <input asp-for="SaturdayService"
                           class="form-control" />
                </div>

            </div>

            <div class="mt-4">

                <button class="btn btn-success">
                    Save Website Settings
                </button>

                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-secondary">
                    Back
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
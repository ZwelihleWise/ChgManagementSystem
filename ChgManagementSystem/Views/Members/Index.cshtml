@model IEnumerable<ChgManagementSystem.Models.Member>

@{
    ViewData["Title"] = "Index";
}
<div class="container mt-4">

    <div class="table-container">

        <h2 class="mb-4">
            Members List
        </h2>

        @if (User.IsInRole("Admin"))
        {
            <p>
                <a asp-action="Create"
                   class="btn btn-primary">
                    Add Member
                </a>
            </p>
        }
        <br />
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="ExportToExcel"
               class="btn btn-success mb-3">
                Export Excel
            </a>
        }
        <br />
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="ExportToPdf"
               class="btn btn-danger mb-3">
                Export PDF
            </a>
        }
<table class="table table-bordered table-striped">

    <thead class="table-dark">
        <tr>
            <th>Full Name</th>
            <th>Phone</th>
            <th>Gender</th>
            <th>Date Joined</th>
            <th>Branch</th>
            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
        <tr>

            <td>
                    @item.FirstName @item.LastName
            </td>

            <td>
                    @item.PhoneNumber
            </td>

            <td>
                    @item.Gender
            </td>

            <td>
                    @item.DateJoined.ToShortDateString()
            </td>

            <td>
                    @item.Branch?.Name
            </td>

                <td>

                    <a asp-action="Details"
                       asp-route-id="@item.Id">
                        Details
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <span>|</span>

                        <a asp-action="Edit"
                           asp-route-id="@item.Id">
                            Edit
                        </a>

                        <span>|</span>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id">
                            Delete
                        </a>
                    }

                </td>

        </tr>
        }

    </tbody>

</table>
    </div>

</div>
@model IEnumerable<ChgManagementSystem.Models.TitheRecord>
@using System.Globalization

@{
    ViewData["Title"] = "Tithe Records";

    decimal totalPaid = Model.Sum(x => x.PaidAmount);
}

<div class="container mt-4">

    <div class="table-container">

        <h1 class="mb-4">
            Tongaat Temple Fund Records
        </h1>

        <!-- MONTH FILTER -->

        <form method="get" class="mb-4">

            <div class="row">

                <div class="col-md-4">

                    <select name="month"
                            class="form-select"
                            onchange="this.form.submit()">

                        @for (int i = 1; i <= 12; i++)
                        {
                            if (ViewBag.SelectedMonth == i)
                            {
                                <option value="@i" selected>
                                    @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                                </option>
                            }
                            else
                            {
                                <option value="@i">
                                    @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                                </option>
                            }
                        }

                    </select>

                </div>

            </div>

        </form>

        <!-- MONTH TOTAL -->

        <div class="alert alert-success mb-3">

            <strong>
                @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName((int)ViewBag.SelectedMonth)
                Total:
            </strong>

            R @totalPaid.ToString("N2")

        </div>

        <!-- BUTTONS -->

        <p>

            <a asp-action="Create"
               class="btn btn-primary">

                Add Payment

            </a>

        </p>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="ExportTithesToExcel"
               class="btn btn-success mb-3">

                Export Excel

            </a>
        }

        <!-- TABLE -->

        <table class="table table-bordered table-hover">

            <thead class="table-dark">

                <tr>

                    <th>Member</th>

                    <th>Month</th>

                    <th>Year</th>

                    <th>Promised</th>

                    <th>Paid</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model.OrderByDescending(x => x.PromisedAmount))
                {
                    <tr>

                        <td>
                            @item.Member.FirstName @item.Member.LastName
                        </td>

                        <td>
                            @DateTimeFormatInfo.CurrentInfo.GetMonthName(item.Month)
                        </td>

                        <td>
                            @item.Year
                        </td>

                        <td>
                            R @item.PromisedAmount.ToString("N2")
                        </td>

                        <td>
                            R @item.PaidAmount.ToString("N2")
                        </td>

                    </tr>
                }

                <tr class="table-success fw-bold">

                    <td colspan="4" class="text-end">

                        TOTAL PAID

                    </td>

                    <td>

                        R @totalPaid.ToString("N2")

                    </td>

                </tr>

            </tbody>

        </table>

    </div>

</div>
@model ChgManagementSystem.Models.BranchLeader

@{
    ViewData["Title"] = "Edit Branch Leader";
}

<div class="container mt-4">

    <h2>Edit Branch Leader</h2>

    <form asp-action="Edit" enctype="multipart/form-data">

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="BranchId" />

        <div class="form-group mb-2">
            <label>Full Name</label>
            <input asp-for="FullName" class="form-control" />
        </div>

        <div class="form-group mb-2">
            <label>Position</label>
            <input asp-for="Position" class="form-control" />
        </div>

        <div class="form-group mb-2">
            <label>Phone Number</label>
            <input asp-for="PhoneNumber" class="form-control" />
        </div>

        <div class="form-group mb-2">
            <label>Description</label>
            <textarea asp-for="Description" class="form-control"></textarea>
        </div>

        @if (!string.IsNullOrEmpty(Model.PhotoPath))
        {
            <div class="mb-3">
                <img src="@Model.PhotoPath"
                     style="height:150px;width:150px;object-fit:cover;"
                     class="rounded" />
            </div>
        }

        <div class="form-group mb-3">
            <label>Replace Photo</label>
            <input type="file" name="Photo" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">
            Save Changes
        </button>

        <a asp-controller="Branches"
           asp-action="Details"
           asp-route-id="@Model.BranchId"
           class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>